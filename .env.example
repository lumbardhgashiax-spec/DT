SUPABASE_URL=https://projekti.supabase.co
SUPABASE_KEY=publishable-or-anon-key

# Server-only. Mos perdor prefiks NUXT_PUBLIC_ dhe mos e publiko ne git.
# Ne Vercel mund te vendosesh njeren nga keto emra.
# Rekomanduar: NUXT_SUPABASE_SECRET_KEY.
# Pranohen edhe: SUPABASE_SECRET_KEY, SUPABASE_SERVICE_ROLE_KEY,
# NUXT_SUPABASE_SERVICE_KEY ose SUPABASE_SERVICE_KEY.
NUXT_SUPABASE_SECRET_KEY=sb_secret_or_service_role_key

# Lere false pervec nese proxy i hosting-ut e pastron dhe e vendos vete
# X-Forwarded-For me IP-ne reale te vizitorit.
NUXT_BOOKING_TRUST_PROXY=false

# Paysera Checkout Modern. Te dyja jane server-only dhe merren nga
# kredencialet OAuth te integrimit Paysera; mos vendos URL, project ID ose fjalekalim.
# Client Secret perdoret edhe per verifikimin HMAC te webhook-ut.
NUXT_PAYSERA_CLIENT_ID=your-paysera-client-id
NUXT_PAYSERA_CLIENT_SECRET=your-paysera-client-secret

# Opsionale: payment link 15 minuta, hold i terminit 20 minuta.
NUXT_PAYSERA_PAYMENT_LINK_LIFETIME_SECONDS=900
NUXT_PAYSERA_RESERVATION_HOLD_SECONDS=1200

# AI Assistant LLM. Endpoint-i duhet te jete OpenAI-compatible.
# Per Ollama ne rrjet vendos base URL pa /v1 ose me /v1; aplikacioni e normalizon vete.
NUXT_ASSISTANT_PROVIDER=openai-compatible
NUXT_ASSISTANT_BASE_URL=http://192.168.0.29:11434
NUXT_ASSISTANT_MODEL=gemma4:12b-mlx
NUXT_ASSISTANT_API_KEY=
NUXT_ASSISTANT_SITE_NAME=Diamond Tennis Academy
NUXT_ASSISTANT_DEVELOPER_NAME=Atomx Solutions SHPK

# Informata publike per faqen e klienteve. Keto vlera mund te shfaqen ne browser.
NUXT_PUBLIC_SITE_URL=https://example.com
NUXT_PUBLIC_DIAMOND_TENNIS_LOCATION_URL=
NUXT_PUBLIC_DIAMOND_TENNIS_INSTAGRAM_URL=https://www.instagram.com/diamond.tennisacademy/
NUXT_PUBLIC_DIAMOND_TENNIS_FACEBOOK_URL=
