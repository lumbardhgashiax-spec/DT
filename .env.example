SUPABASE_URL=https://projekti.supabase.co
SUPABASE_KEY=publishable-or-anon-key

# Vetëm në server. Mos përdorni prefiks NUXT_PUBLIC_ dhe mos e publikoni në git.
NUXT_SUPABASE_SECRET_KEY=sb_secret_or_service_role_key

# Lere false pervec nese proxy i hosting-ut e pastron dhe e vendos vete
# X-Forwarded-For me IP-ne reale te vizitorit.
NUXT_BOOKING_TRUST_PROXY=false

# Vetem ne server. Mos perdorni prefiks NUXT_PUBLIC_ dhe mos e publikoni ne git.
NUXT_OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
NUXT_OPENROUTER_MODEL=openai/gpt-4o
NUXT_OPENROUTER_SITE_URL=https://example.com
NUXT_OPENROUTER_SITE_NAME=Diamond Tennis Academy

# Informata publike per faqen e klienteve. Keto vlera mund te shfaqen ne browser.
NUXT_PUBLIC_SITE_URL=https://example.com
NUXT_PUBLIC_DIAMOND_TENNIS_LOCATION_URL=
NUXT_PUBLIC_DIAMOND_TENNIS_INSTAGRAM_URL=https://www.instagram.com/diamond.tennisacademy/
NUXT_PUBLIC_DIAMOND_TENNIS_FACEBOOK_URL=
